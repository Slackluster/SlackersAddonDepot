<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
	<Frame name="SlackersAddonDepot_SettingsText" mixin="SlackersAddonDepot_SettingsTextMixin" virtual="true">
		<Size y="28" />
		<Layers>
			<Layer level="OVERLAY">
				<FontString parentKey="LeftText" inherits="GameFontNormal" justifyH="LEFT" justifyV="TOP">
					<Anchors>
						<Anchor point="TOPLEFT" x="37" y="-8" />
					</Anchors>
				</FontString>
				<FontString parentKey="MiddleText" inherits="GameFontNormal" justifyH="LEFT" justifyV="TOP">
					<Anchors>
						<Anchor point="TOPLEFT" x="240" y="-8" />
					</Anchors>
				</FontString>
				<FontString parentKey="RightText" inherits="GameFontNormal" justifyH="LEFT" justifyV="TOP">
					<Anchors>
						<Anchor point="TOPLEFT" x="280" y="-8" />
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
	</Frame>

	<Frame name="SlackersAddonDepot_SettingsExpandTemplate" inherits="SettingsExpandableSectionTemplate" mixin="SlackersAddonDepot_SettingsExpandMixin" virtual="true">
		<Size y="24" />
	</Frame>

	<Button name="SlackersAddonDepot_AddonListHeader" virtual="true">
		<Size x="200" y="22" />
		<HighlightTexture atlas="Options_List_Hover" setAllPoints="true" />
		<Layers>
			<Layer level="OVERLAY">
				<FontString parentKey="Text1" inherits="GameFontNormalMed1" justifyH="LEFT" wordwrap="false">
					<Anchors>
						<Anchor point="LEFT" x="23" y="1" />
						<Anchor point="RIGHT" x="-22" />
					</Anchors>
					<Size x="400" y="24" />
				</FontString>
			</Layer>
		</Layers>
	</Button>

	<Button name="SlackersAddonDepot_AddonListAddon" virtual="true">
		<Size x="200" y="22" />
		<HighlightTexture atlas="Options_List_Hover" setAllPoints="true" />
		<Layers>
			<Layer level="OVERLAY">
				<FontString parentKey="Icon" inherits="GameFontNormalMed1" justifyH="LEFT">
					<Anchors>
						<Anchor point="LEFT" x="32" />
					</Anchors>
					<Size x="400" y="24" />
				</FontString>
				<FontString parentKey="Text1" inherits="GameFontNormalMed1" justifyH="LEFT" wordwrap="false">
					<Anchors>
						<Anchor point="LEFT" x="55" y="1" />
						<Anchor point="RIGHT" x="-22" />
					</Anchors>
					<Size x="400" y="24" />
				</FontString>
				<FontString parentKey="Text2" inherits="GameFontNormal" justifyH="RIGHT">
					<Anchors>
						<Anchor point="RIGHT" x="-5" />
					</Anchors>
					<Size x="400" y="24" />
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<CheckButton parentKey="Checkbox" inherits="MinimalCheckboxArtTemplate">
				<Size x="24" y="24"/>
				<Anchors>
					<Anchor point="LEFT" x="5" y="0"/>
				</Anchors>
				<HitRectInsets>
					<AbsInset left="0" right="0" top="0" bottom="8"/>
				</HitRectInsets>
			</CheckButton>
		</Frames>
	</Button>

	<Button name="SlackersAddonDepot_AddonListDependency" virtual="true">
		<Size x="200" y="22" />
		<HighlightTexture atlas="Options_List_Hover" setAllPoints="true" />
		<Layers>
			<Layer level="OVERLAY">
				<FontString parentKey="Icon" inherits="GameFontNormalMed1" justifyH="LEFT">
					<Anchors>
						<Anchor point="LEFT" x="39" />
					</Anchors>
					<Size x="400" y="24" />
				</FontString>
				<FontString parentKey="Text1" inherits="GameFontNormalMed1" justifyH="LEFT" wordwrap="false">
					<Anchors>
						<Anchor point="LEFT" x="62" y="1" />
						<Anchor point="RIGHT" x="-22" />
					</Anchors>
					<Size x="400" y="24" />
				</FontString>
				<FontString parentKey="Text2" inherits="GameFontNormal" justifyH="RIGHT">
					<Anchors>
						<Anchor point="RIGHT" x="-5" />
					</Anchors>
					<Size x="400" y="24" />
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<CheckButton parentKey="Checkbox" inherits="MinimalCheckboxArtTemplate">
				<Size x="24" y="24"/>
				<Anchors>
					<Anchor point="LEFT" x="12" y="0"/>
				</Anchors>
				<HitRectInsets>
					<AbsInset left="0" right="0" top="0" bottom="8"/>
				</HitRectInsets>
			</CheckButton>
		</Frames>
	</Button>
</Ui>
